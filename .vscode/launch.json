{
  "version": "0.2.0",
  "configurations": [
    {
      "name": ".NET Launch demoTestHostApi",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build demoTestHostApi",
      "program": "${workspaceFolder}/demoTestHostApi/bin/Debug/net10.0/demoTestHostApi.dll",
      "args": [],
      "cwd": "${workspaceFolder}/demoTestHostApi",
      "stopAtEntry": false,
      "console": "internalConsole",
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_URLS": "https://localhost:7047;http://localhost:5186"
      },
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
      }
    }
  ]
}