{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build demoTestHostApi",
      "type": "process",
      "command": "dotnet",
      "args": [
        "build",
        "${workspaceFolder}/demoTestHostApi/demoTestHostApi.csproj"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": "$msCompile"
    },
    {
      "label": "build solution",
      "type": "process",
      "command": "dotnet",
      "args": [
        "build",
        "${workspaceFolder}/demoTestHost.sln"
      ],
      "problemMatcher": "$msCompile"
    },
    {
      "label": "test solution",
      "type": "process",
      "command": "dotnet",
      "args": [
        "test",
        "${workspaceFolder}/demoTestHost.sln"
      ],
      "group": "test",
      "problemMatcher": "$msCompile"
    }
  ]
}